# ============================================
# oh-my-opensecret 配置示例
# ============================================
# 用法：
#   1. 复制此文件到项目根目录，重命名为 oh-my-opensecret.yaml
#   2. 按需修改配置项
#   3. 重启 Opencode 使配置生效
#
# 首次启动若无配置，插件会自动生成一份默认配置（等同于本文件不带 profile）。
# 你随时修改 YAML 文件，下次启动自动生效。
#
# 配置查找优先级（从高到低）：
#   1. $OPENCODE_SECRET_CONFIG 环境变量指向的文件
#   2. 项目根目录下的 oh-my-opensecret.yaml
#   3. 项目根目录 .opencode/ 下的 oh-my-opensecret.yaml
#   4. ~/.config/opencode/oh-my-opensecret.yaml（用户全局）
#   5. 以上都不存在则自动生成默认配置到 ~/.config/opencode/oh-my-opensecret.yaml
# ============================================


# ---------- 基本开关 ----------

# 是否启用插件。
#   true  — 启用脱敏/还原（默认）
#   false — 完全禁用，注册空 hook，不执行任何操作
enabled: true


# ---------- 日志配置 ----------

# level:  输出级别 debug/info/warn/error（默认 info）
# file:   日志文件路径（默认 ~/.oh-my-opensecret/oh-my-opensecret.log）
# rotation:
#   max_size:  滚动阈值（默认 "10m"，支持 500k/10m/1g）
#   max_files: 保留历史文件数（默认 7），超出删除最旧
# 滚动规则：文件大小超限或日期变更时触发。
# 历史文件名格式: oh-my-opensecret.2026-06-04.1.log
logging:
  level: info
  file: ~/.oh-my-opensecret/oh-my-opensecret.log
  # rotation:
  #   max_size: "10m"
  #   max_files: 7


# ---------- 自动发现 ----------

# 启动时自动扫描 Opencode 配置（opencode.json / opencode.jsonc），
# 从中提取 apiKey / token / secret / password 等敏感字段的值，
# 自动生成对应的正则规则并追加到配置文件中。
#
# 已存在的规则跳过，同 placeholder-id 但 pattern 不同的视为冲突项，
# 以 YAML 注释 # auto-discovered: ... 写入，不覆盖现有配置。
#
# 仅在 enabled: true 时生效。
auto_discovery: true


# ---------- 占位符 ----------

# 脱敏后占位符的前缀。
# 完整格式：#{PREFIX}_{CATEGORY}_{hash12}__
# 例如：__OMOS_OPENAI_KEY_ab12cd34ef56__
# 自定义前缀时确保不含 YAML 特殊字符。
placeholder_prefix: "__OMOS_"


# ---------- 会话管理 ----------

# 占位符与原文的映射关系在 session 维度维护。
# 每次 LLM 请求（sessionID）创建独立的空间，互不干扰。
session:
  # 占位符有效期（超过此时间的映射自动清理）。
  # 格式: 数字 + 单位 (ms/s/m/h/d)
  ttl: "1h"

  # 单个 session 最多维护的映射数。
  # 超过此上限时淘汰最早使用的映射（LRU）。
  max_mappings: 100000


# ============================================
# 匹配规则
# ============================================
# 当未设置 profile 时，使用下方的 patterns 作为基准规则。
# 当设置了 profile，合并规则如下：
#   keywords/regex — 拼接（base + profile），不覆盖
#   builtin        — profile 覆盖 base，profile 未指定则回退 base
#   exclude        — profile 覆盖 base，profile 未指定则回退 base
# ============================================

patterns:

  # ---------- 关键词匹配（精确子串） ----------

  # 按原文精确匹配（非正则），适合固定的敏感词。
  # 例：防止项目中提及某个内部系统名
  keywords: []

  # ---------- 自定义正则规则 ----------

  # 每个规则两个字段：
  #   pattern:  正则表达式，支持 /regex/flags 字面量语法，
  #             如 "/[a-z]+/gi"，也支持 (?i)(?m)(?s) 内联前缀。
  #   placeholder-id: 分类名，用于占位符标识（仅用于日志和调试）
  #
  # 以下为示例规则，实际生效的是内置规则 + 此处的自定义规则。
  # 你可以按平台格式添加更多自定义规则。
  regex:
    - pattern: "sk-[A-Za-z0-9]{48}"
      placeholder-id: "OPENAI_KEY"
    - pattern: "(ghp|gho|ghu|ghs|ghr)_[A-Za-z0-9]+"
      placeholder-id: "GITHUB_TOKEN"
    - pattern: "AKIA[0-9A-Z]{16}"
      placeholder-id: "AWS_ACCESS_KEY"

  # ---------- 内置规则列表 ----------
  #
  # 从下方列表中选择要启用的内置规则，按名称引用即可。
  # 内置规则仅覆盖通用 PII，不包含任何平台 API Key。
  # API Key 请在上方 regex 中添加自定义规则。
  #
  # 可用内置规则：
  #   - email          邮箱地址
  #   - china_phone    中国大陆手机号
  #   - china_id       中国大陆身份证号
  #   - uuid           UUID
  #   - ipv4           IPv4 地址
  #   - ipv6           IPv6 地址
  #   - mac            MAC 地址
  #   - jwt            JWT Token
  #   - db_connection  数据库连接串
  builtin:
    - email
    - china_phone
    - china_id
    - uuid
    - ipv4
    - ipv6
    - mac
    - jwt
    - db_connection

  # ---------- 排除列表（白名单/豁免） ----------

  # 此处列出的内容不会被脱敏，即使匹配了任何规则。
  # 支持多个值，精确匹配原文（非正则）。
  # 适用于：内网地址、示例域名、测试数据等。
  exclude:
    - "example.com"
    - "localhost"
    - "127.0.0.1"
    - "0.0.0.0"


